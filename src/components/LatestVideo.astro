---
import BentoCard from "./BentoCard.astro";
---

<BentoCard title="最新の動画（3分以上）" icon="🆕" class="h-full">
  <div id="latest-video-slot">
    <div class="aspect-video rounded-xl bg-gray-100 animate-pulse"></div>
    <p class="mt-3 text-sm text-gray-400">読み込み中...</p>
  </div>
</BentoCard>

<script>
  async function loadLatest() {
    const slot = document.getElementById("latest-video-slot");
    if (!slot) return;
    if ((window as any).__isYouTubeLimited?.()) {
      (window as any).__showYouTubeLimitBanner?.();
      slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-8">いま動画を取りに行けません…！上の案内をチェックしてね。</p>`;
      return;
    }
    try {
      const res = await fetch("/.netlify/functions/youtube-proxy?type=latest");
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        const limited = data?.reason === "quotaExceeded" || data?.reason === "rateLimitExceeded";
        if (limited) (window as any).__markYouTubeLimited?.(data.reason);
        if (limited) (window as any).__showYouTubeLimitBanner?.();
        slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-8">いま動画を取りに行けません…！上の案内をチェックしてね。</p>`;
        return;
      }
      const video = data.videos?.[0];

      if (!video) {
        slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-8">動画が見つからなかったよ（公開待ち/反映待ちかも）</p>`;
        return;
      }

      slot.innerHTML = `
        <a href="https://www.youtube.com/watch?v=${video.id}" target="_blank" rel="noopener noreferrer"
           class="group block">
          <div class="overflow-hidden rounded-xl">
            <img src="${video.thumbnail}" alt="${video.title}" loading="lazy"
                 class="w-full aspect-video object-cover transition-transform duration-300 group-hover:scale-105" />
          </div>
          <p class="mt-3 text-sm font-bold text-gray-800 leading-snug group-hover:text-brand transition-colors">
            ${video.title}
          </p>
        </a>`;
    } catch {
      slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-8">通信が不安定かも。時間を置いてもう一度どうぞ。</p>`;
    }
  }

  loadLatest();
</script>
