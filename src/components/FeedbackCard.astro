---
import BentoCard from "./BentoCard.astro";
---

<BentoCard title="ご意見箱" icon="📬" class="h-full">
  <p class="text-sm text-gray-600 mb-4">
    活動全般について、改善点ややってほしい企画など、匿名でご意見をお聞かせください。
  </p>
  <a
    href="https://docs.google.com/forms/d/e/1FAIpQLSd07jq1QJVpjXTNwebNOhCfSfOzQtInPFdYl3VEdsMnc6O-Ng/viewform?usp=dialog"
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-2 bg-gray-100 text-gray-700 font-bold text-sm py-2 px-5 rounded-full hover:bg-brand hover:text-white transition-all"
  >
    匿名で意見を送る
    <span>↗</span>
  </a>
</BentoCard>
