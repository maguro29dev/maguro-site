---
import BentoCard from "./BentoCard.astro";
---

<BentoCard title="今月のショート" icon="⚡" class="h-full">
  <p class="text-xs text-gray-400 mb-3">3分未満の動画。サクッと見たいときにどうぞ。</p>
  <div id="short-videos-slot" class="flex gap-3 overflow-x-auto pb-2 -mx-1 px-1 scrollbar-hide">
    {Array.from({ length: 4 }).map(() => (
      <div class="flex-shrink-0 w-28">
        <div class="aspect-[9/16] rounded-lg bg-gray-100 animate-pulse"></div>
        <div class="h-3 w-full rounded bg-gray-100 mt-2 animate-pulse"></div>
      </div>
    ))}
  </div>
</BentoCard>

<script>
  async function loadShorts() {
    const slot = document.getElementById("short-videos-slot");
    if (!slot) return;
    if ((window as any).__isYouTubeLimited?.()) {
      (window as any).__showYouTubeLimitBanner?.();
      slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-4 w-full">いまショートを取りに行けません…！上の案内をチェックしてね。</p>`;
      return;
    }
    try {
      const res = await fetch("/.netlify/functions/youtube-proxy?type=shorts");
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        const limited = data?.reason === "quotaExceeded" || data?.reason === "rateLimitExceeded";
        if (limited) (window as any).__markYouTubeLimited?.(data.reason);
        if (limited) (window as any).__showYouTubeLimitBanner?.();
        slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-4 w-full">いまショートを取りに行けません…！上の案内をチェックしてね。</p>`;
        return;
      }
      const videos = data.videos || [];

      if (!videos.length) {
        slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-4 w-full">今月のショートはまだありません</p>`;
        return;
      }

      slot.innerHTML = videos
        .map(
          (v: { id: string; title: string; thumbnail: string; viewCount: number }) => `
        <a href="https://www.youtube.com/watch?v=${v.id}" target="_blank" rel="noopener noreferrer"
           class="group flex-shrink-0 w-28">
          <div class="overflow-hidden rounded-lg aspect-[9/16] bg-gray-100">
            <img src="${v.thumbnail}" alt="${v.title}" loading="lazy"
                 class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
          </div>
          <p class="mt-1.5 text-[10px] font-bold text-gray-700 leading-snug line-clamp-2 group-hover:text-brand transition-colors">${v.title}</p>
          <p class="text-[9px] text-gray-400">${v.viewCount.toLocaleString()} 回</p>
        </a>`
        )
        .join("");
    } catch {
      slot.innerHTML = `<p class="text-gray-400 text-sm text-center py-4 w-full">通信が不安定かも。時間を置いてもう一度どうぞ。</p>`;
    }
  }

  loadShorts();
</script>
