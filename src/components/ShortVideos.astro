---
import BentoCard from "./BentoCard.astro";
---

<BentoCard title="今月のショート" icon="⚡" class="h-full">
  <p class="text-xs text-gray-400 mb-3">3分未満の動画。サクッと見たいときにどうぞ。</p>
  <div id="short-videos-slot" class="flex gap-3 overflow-x-auto pb-2 -mx-1 px-1 scrollbar-hide">
    {Array.from({ length: 4 }).map(() => (
      <div class="flex-shrink-0 w-28">
        <div class="aspect-[9/16] rounded-lg bg-gray-100 animate-pulse"></div>
        <div class="h-3 w-full rounded bg-gray-100 mt-2 animate-pulse"></div>
      </div>
    ))}
  </div>
</BentoCard>
