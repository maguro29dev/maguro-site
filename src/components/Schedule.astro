---
import type { ScheduleItem, RealEvent } from "@/lib/data";

interface Props {
  weeklySchedule: ScheduleItem[];
  realEvents: RealEvent[];
  weeklyScheduleUpdatedAt: string;
}

const { weeklySchedule, realEvents, weeklyScheduleUpdatedAt } = Astro.props;
---

<div
  class="col-span-full block bg-white rounded-2xl shadow-sm border border-gray-100 transition-all duration-300 hover:shadow-md relative overflow-hidden"
  id="schedule-card"
  data-schedule-updated-at={weeklyScheduleUpdatedAt}
>
  <div class="p-5">
    <div class="flex items-center gap-2 mb-5">
      <span class="text-2xl">🗓️</span>
      <h2 class="text-lg font-bold text-gray-800">スケジュール</h2>
    </div>

    <div
      id="schedule-stale-banner"
      class="hidden mb-4 rounded-xl bg-amber-50 border border-amber-200/80 px-4 py-3 text-sm text-amber-950 leading-relaxed"
      role="status"
    >
      <p class="font-bold">週間スケジュール、更新し忘れてるかも…！</p>
      <p class="mt-1 text-amber-900/90">
        まぐにぃを
        <a href="https://x.com/maguro29" target="_blank" rel="noopener noreferrer" class="font-bold underline hover:text-amber-700">X</a>・
        <a href="https://discord.gg/YabfK2buHm" target="_blank" rel="noopener noreferrer" class="font-bold underline hover:text-amber-700">Discord DM</a>・
        YouTubeコメント欄など、お好きな手段で<strong class="font-bold">優しく煽って</strong>ください。
      </p>
    </div>

    <div id="schedule-capture-area" class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Upcoming streams (client-side) -->
      <div>
        <h3 class="text-sm font-bold text-brand mb-3 flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-red-500"></span>
          配信予定
        </h3>
        <div id="upcoming-schedule" class="space-y-2">
          <p class="text-gray-400 text-sm py-2">読み込み中...</p>
        </div>
      </div>

      <!-- Weekly schedule (static) -->
      <div>
        <h3 class="text-sm font-bold text-brand mb-3 flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-brand"></span>
          週間スケジュール
        </h3>
        <div id="weekly-schedule-list" class="space-y-2">
          {weeklySchedule.length > 0 ? (
            weeklySchedule.map((day) => (
              <div class="schedule-day flex items-center gap-3 p-2.5 rounded-lg bg-gray-50 hover:bg-brand-50 transition-colors" data-day={day.day}>
                <span class="schedule-day-label text-sm font-bold text-gray-600 w-[4.5rem] shrink-0">{day.day}</span>
                <span class="text-sm text-gray-800">{day.time} {day.plan}</span>
              </div>
            ))
          ) : (
            <p class="text-gray-400 text-sm py-2">スケジュールは準備中です</p>
          )}
        </div>
      </div>
    </div>

    {realEvents.length > 0 && (
      <div class="mt-6 pt-5 border-t border-gray-100">
        <h3 class="text-sm font-bold text-brand mb-3 flex items-center gap-1.5">
          <span class="w-2 h-2 rounded-full bg-amber-500"></span>
          リアルイベント
        </h3>
        <div class="space-y-2">
          {realEvents.map((ev) => {
            const isExternal = ev.url.startsWith("http");
            return (
            <a
              href={ev.url}
              target={isExternal ? "_blank" : undefined}
              rel={isExternal ? "noopener noreferrer" : undefined}
              class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-50 hover:bg-brand-50 transition-colors"
            >
              <span class="text-sm font-bold text-red-600 w-20 shrink-0">{ev.date}</span>
              <span class="text-sm font-bold text-gray-800">{ev.title}</span>
            </a>
            );
          })}
        </div>
      </div>
    )}

    <p class="text-xs text-red-500 font-medium mt-4">
      ※ 時間や内容はXでお知らせします！
    </p>
  </div>

  <!-- Screenshot button -->
  <button
    id="capture-schedule-btn"
    title="スケジュールを画像として保存"
    class="absolute bottom-4 right-4 w-11 h-11 bg-brand text-white rounded-full flex items-center justify-center shadow-md hover:scale-110 hover:bg-brand-dark transition-all text-lg z-10"
  >
    📷
  </button>
</div>

<script>
  // #region agent log
  function dbg(location, message, data, hypothesisId) {
    fetch("http://127.0.0.1:7454/ingest/6f256a33-7dae-46ab-90eb-f1af3c449825", {
      method: "POST",
      headers: { "Content-Type": "application/json", "X-Debug-Session-Id": "1aca79" },
      body: JSON.stringify({
        sessionId: "1aca79",
        location,
        message,
        data,
        hypothesisId,
        runId: "schedule-screenshot",
        timestamp: Date.now(),
      }),
    }).catch(() => {});
  }
  // #endregion

  async function loadUpcoming() {
    const slot = document.getElementById("upcoming-schedule");
    if (!slot) return;
    try {
      const res = await fetch("/.netlify/functions/youtube-proxy?type=upcoming");
      const data = await res.json();
      const videos = data.videos || [];

      if (!videos.length) {
        slot.innerHTML = `<p class="text-gray-400 text-sm py-2">現在予定されている配信はありません</p>`;
        return;
      }

      slot.innerHTML = videos
        .map((v) => {
          const d = new Date(v.scheduledStart);
          const dateStr = `${d.getMonth() + 1}/${d.getDate()} ${String(d.getHours()).padStart(2, "0")}:${String(d.getMinutes()).padStart(2, "0")}`;
          return `
            <a href="https://www.youtube.com/watch?v=${v.id}" target="_blank" rel="noopener noreferrer"
               class="flex items-center gap-3 p-2.5 rounded-lg bg-gray-50 hover:bg-brand-50 transition-colors">
              <span class="text-sm font-bold text-red-600 w-20 shrink-0">${dateStr}</span>
              <span class="text-sm text-gray-800">${v.title}</span>
            </a>`;
        })
        .join("");
    } catch {
      slot.innerHTML = `<p class="text-gray-400 text-sm py-2">読み込みに失敗しました</p>`;
    }
  }

  function mondayStart(d = new Date()) {
    const date = new Date(d);
    const day = date.getDay();
    const diff = day === 0 ? 6 : day - 1;
    date.setHours(0, 0, 0, 0);
    date.setDate(date.getDate() - diff);
    return date;
  }

  function initSchedule() {
    // #region agent log
    dbg("Schedule.astro:init", "schedule script started", {}, "A");
    // #endregion

    const card = document.getElementById("schedule-card");
    const weeklyScheduleUpdatedAt = card?.dataset.scheduleUpdatedAt ?? "";

    loadUpcoming();

    const updated = new Date(`${weeklyScheduleUpdatedAt}T12:00:00`);
    if (updated < mondayStart()) {
      document.getElementById("schedule-stale-banner")?.classList.remove("hidden");
    }

    const dayNames = ["日曜日", "月曜日", "火曜日", "水曜日", "木曜日", "金曜日", "土曜日"];
    const todayName = dayNames[new Date().getDay()];
    document.querySelectorAll(".schedule-day").forEach((el) => {
      if (!(el instanceof HTMLElement) || el.dataset.day !== todayName) return;

      el.classList.remove("bg-gray-50");
      el.classList.add("bg-brand-50", "ring-1", "ring-brand/30");

      const label = el.querySelector(".schedule-day-label");
      if (!label) return;

      label.classList.replace("text-gray-600", "text-brand");
      const badge = document.createElement("span");
      badge.className =
        "mt-0.5 inline-block text-[10px] font-bold text-white bg-brand px-1.5 py-0.5 rounded-full leading-none";
      badge.textContent = "今日";
      label.appendChild(badge);
    });

    const captureBtn = document.getElementById("capture-schedule-btn");
    // #region agent log
    dbg("Schedule.astro:captureBtn", "capture button lookup", { found: !!captureBtn }, "D");
    // #endregion

    if (!captureBtn || !(captureBtn instanceof HTMLButtonElement)) return;

    captureBtn.addEventListener("click", async () => {
      const target = document.getElementById("schedule-capture-area");
      // #region agent log
      dbg("Schedule.astro:click", "screenshot click", { hasTarget: !!target }, "E");
      // #endregion
      if (!target) return;

      captureBtn.textContent = "...";
      captureBtn.disabled = true;

      try {
        // #region agent log
        dbg("Schedule.astro:import", "loading html2canvas", {}, "B");
        // #endregion
        const { default: html2canvas } = await import(
          "https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.esm.js"
        );
        const canvas = await html2canvas(target, {
          useCORS: true,
          backgroundColor: "#ffffff",
          scale: 2,
        });
        const link = document.createElement("a");
        link.download = "schedule.png";
        link.href = canvas.toDataURL("image/png");
        link.click();
        // #region agent log
        dbg("Schedule.astro:success", "screenshot saved", { width: canvas.width, height: canvas.height }, "C");
        // #endregion
      } catch (e) {
        const errMsg = e instanceof Error ? e.message : String(e);
        // #region agent log
        dbg("Schedule.astro:error", "screenshot failed", { errMsg }, "B");
        // #endregion
        console.error("Screenshot failed:", e);
        alert("画像の保存に失敗しました。");
      } finally {
        captureBtn.textContent = "📷";
        captureBtn.disabled = false;
      }
    });
  }

  initSchedule();
</script>
