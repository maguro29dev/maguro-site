---
/**
 * Live status & countdown. Fetches data client-side for real-time accuracy.
 * Renders as an island with client:load.
 */
---

<div id="live-status" class="fade-up">
  <div
    id="live-status-content"
    class="rounded-2xl p-5 text-center transition-all duration-500"
  >
    <p class="text-gray-400 text-sm">配信情報を読み込み中...</p>
  </div>
</div>

<script>
  let refreshTimer: number | null = null;

  function isLimitedReason(reason?: string) {
    return reason === "quotaExceeded" || reason === "rateLimitExceeded";
  }

  async function fetchYouTube(type: string) {
    if ((window as any).__isYouTubeLimited?.()) {
      return { __error: true, reason: "quotaExceeded" };
    }
    try {
      const res = await fetch(`/.netlify/functions/youtube-proxy?type=${type}`);
      const data = await res.json().catch(() => ({}));
      if (!res.ok) {
        if (isLimitedReason(data?.reason)) {
          (window as any).__markYouTubeLimited?.(data.reason);
        }
        return {
          __error: true,
          status: res.status,
          reason: data?.reason,
        };
      }
      return data;
    } catch {
      return { __error: true, status: 0 };
    }
  }

  function startCountdown(targetTime: string, el: HTMLElement) {
    const target = new Date(targetTime).getTime();

    function update() {
      const now = Date.now();
      const distance = target - now;

      if (distance < 0) {
        el.innerHTML = `<span class="text-brand font-bold text-xl">まもなく開始します！</span>`;
        setTimeout(() => location.reload(), 5000);
        return;
      }

      const d = Math.floor(distance / 86400000);
      const h = Math.floor((distance % 86400000) / 3600000);
      const m = Math.floor((distance % 3600000) / 60000);
      const s = Math.floor((distance % 60000) / 1000);

      const parts: string[] = [];
      if (d > 0) parts.push(`<span class="tabular-nums">${String(d).padStart(2, "0")}</span><span class="text-lg mx-0.5">日</span>`);
      parts.push(`<span class="tabular-nums">${String(h).padStart(2, "0")}</span><span class="text-lg mx-0.5">時間</span>`);
      parts.push(`<span class="tabular-nums">${String(m).padStart(2, "0")}</span><span class="text-lg mx-0.5">分</span>`);
      parts.push(`<span class="tabular-nums">${String(s).padStart(2, "0")}</span><span class="text-lg mx-0.5">秒</span>`);
      el.innerHTML = parts.join("");

      requestAnimationFrame(update);
    }

    update();
  }

  async function init() {
    const container = document.getElementById("live-status-content");
    if (!container) return;

    if ((window as any).__isYouTubeLimited?.()) {
      (window as any).__showYouTubeLimitBanner?.();
      container.className =
        "rounded-2xl p-5 bg-white shadow-sm border border-gray-100 text-center transition-all duration-500";
      container.innerHTML = `
        <p class="text-gray-600 font-bold">配信情報、いま取りに行けません…！</p>
        <p class="text-xs text-gray-400 mt-1">上の案内にしたがって再読み込みしてみてね。</p>`;
      if (refreshTimer) {
        window.clearInterval(refreshTimer);
        refreshTimer = null;
      }
      return;
    }

    const liveData = await fetchYouTube("live");

    if (liveData?.isLive && liveData.video) {
      container.className = "rounded-2xl p-5 bg-red-600 text-white shadow-lg cursor-pointer transition-all duration-500";
      container.innerHTML = `
        <a href="https://www.youtube.com/watch?v=${liveData.video.id}" target="_blank" rel="noopener noreferrer"
           class="flex items-center justify-center gap-3">
          <span class="relative flex h-4 w-4">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white opacity-75"></span>
            <span class="relative inline-flex rounded-full h-4 w-4 bg-white"></span>
          </span>
          <span class="text-lg font-bold">ライブ配信中！「${liveData.video.title}」</span>
        </a>`;
      return;
    }

    const upcomingData = await fetchYouTube("upcoming");

    // If the API is quota/rate limited, show a friendly message + manual refresh.
    if (liveData?.__error || upcomingData?.__error) {
      const reason = liveData?.reason || upcomingData?.reason;
      const limited = isLimitedReason(reason);

      if (limited) {
        (window as any).__showYouTubeLimitBanner?.();
        if (refreshTimer) {
          window.clearInterval(refreshTimer);
          refreshTimer = null;
        }
        container.className =
          "rounded-2xl p-5 bg-white shadow-sm border border-gray-100 text-center transition-all duration-500";
        container.innerHTML = `
          <p class="text-gray-600 font-bold">配信情報、いま取りに行けません…！</p>
          <p class="text-xs text-gray-400 mt-1">上の案内にしたがって再読み込みしてみてね。</p>`;
        return;
      }
    }

    if (upcomingData?.videos?.length > 0) {
      const next = upcomingData.videos[0];
      container.className = "rounded-2xl p-6 bg-white shadow-sm border border-gray-100 text-center transition-all duration-500";
      container.innerHTML = `
        <p class="text-sm font-bold text-gray-500 mb-2">次回の配信まで</p>
        <div id="countdown" class="text-4xl md:text-5xl font-black text-gray-900 tracking-tight"></div>
        <a href="https://www.youtube.com/watch?v=${next.id}" target="_blank" rel="noopener noreferrer"
           class="text-xs text-gray-400 mt-2 inline-block hover:text-brand transition-colors">${next.title}</a>`;
      startCountdown(next.scheduledStart, document.getElementById("countdown")!);
      return;
    }

    container.className = "rounded-2xl p-5 bg-white shadow-sm border border-gray-100 text-center transition-all duration-500";
    container.innerHTML = `
      <p class="text-gray-500 font-medium mb-3">次回の配信は未定です</p>
      <a href="https://x.com/maguro29" target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 text-sm font-bold text-gray-600 hover:text-gray-900 transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Xをフォローして配信情報をチェック
      </a>`;
  }

  // Re-fetch on bfcache restore / tab return and periodically.
  init();
  window.addEventListener("pageshow", (e) => {
    if (e.persisted) init();
  });
  document.addEventListener("visibilitychange", () => {
    if (!document.hidden) init();
  });
  // Be conservative with API usage: refresh every 5 minutes.
  refreshTimer = window.setInterval(() => init(), 5 * 60 * 1000);
</script>
