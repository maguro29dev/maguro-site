---
import Base from "@/layouts/Base.astro";
import BentoCard from "@/components/BentoCard.astro";
import { siteMeta } from "@/data/site-meta";
import {
  homekuraMeta,
  homekuraIntro,
  watchGuide,
  scheduleItems,
  buzzwordAward,
  viewerGuidelines,
  forCreators,
  homekuraLinks,
} from "@/data/homekura";
---

<Base
  title={`${homekuraMeta.pageTitle} | ${siteMeta.siteName}`}
  description={homekuraMeta.description}
>
  <div class="max-w-6xl mx-auto px-4 py-8 pb-28 sm:pb-10 space-y-8">
    <!-- Hero -->
    <section class="fade-up text-center space-y-4 py-4">
      <p class="text-sm font-bold text-brand tracking-wide">homeクラ Season 2</p>
      <h1 class="text-3xl sm:text-4xl font-black text-gray-900 leading-tight">
        {homekuraMeta.pageTitle}
      </h1>
      <p class="max-w-2xl mx-auto text-gray-600 leading-relaxed">
        配信者専用 Minecraft サバイバルを、<strong class="text-gray-800">視聴者の視点</strong>から楽しむためのガイドです。
      </p>
      <p class="text-xs text-gray-400">最終更新: {homekuraMeta.updatedAt}</p>
    </section>

    <!-- Intro -->
    <section class="fade-up">
      <BentoCard title={homekuraIntro.title} icon="🏠">
        <p class="text-gray-700 leading-relaxed mb-4" set:html={homekuraIntro.lead.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")} />
        <ul class="space-y-2">
          {homekuraIntro.points.map((point) => (
            <li class="flex gap-2 text-sm text-gray-600 leading-relaxed">
              <span class="text-brand shrink-0">●</span>
              <span set:html={point.replace(/\*\*(.+?)\*\*/g, "<strong class='text-gray-800'>$1</strong>")} />
            </li>
          ))}
        </ul>
      </BentoCard>
    </section>

    <!-- Watch guide -->
    <section class="fade-up">
      <BentoCard title={watchGuide.title} icon="👀">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          {watchGuide.items.map((item) => (
            <div class="rounded-xl bg-brand-50/80 border border-brand/15 p-4">
              <p class="text-2xl mb-2">{item.icon}</p>
              <h3 class="font-bold text-gray-800 mb-2">{item.heading}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
            </div>
          ))}
        </div>
      </BentoCard>
    </section>

    <!-- Schedule -->
    <section class="fade-up">
      <BentoCard title="スケジュール（視聴者向け）" icon="📅">
        <div class="space-y-3">
          {scheduleItems.map((item) => (
            <div
              class:list={[
                "rounded-xl p-4 border",
                item.highlight
                  ? "bg-brand-50 border-brand/25"
                  : "bg-gray-50 border-gray-100",
              ]}
            >
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
                <time class="text-sm font-black text-brand shrink-0">{item.date}</time>
                <h3 class="font-bold text-gray-800">{item.title}</h3>
              </div>
              <p
                class="mt-2 text-sm text-gray-600 leading-relaxed"
                set:html={item.detail.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")}
              />
            </div>
          ))}
        </div>
      </BentoCard>
    </section>

    <!-- Buzzword award -->
    <section class="fade-up">
      <BentoCard title={buzzwordAward.title} icon="🏆">
        <ol class="space-y-3 mb-4">
          {buzzwordAward.steps.map((step, i) => (
            <li class="flex gap-3 text-sm text-gray-700 leading-relaxed">
              <span class="flex items-center justify-center w-6 h-6 rounded-full bg-brand text-white text-xs font-black shrink-0">
                {i + 1}
              </span>
              <span set:html={step.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")} />
            </li>
          ))}
        </ol>
        <div class="flex flex-wrap gap-2">
          <a
            href={buzzwordAward.xPostUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded-full bg-gray-900 text-white text-sm font-bold hover:bg-gray-700 transition-colors"
          >
            X の募集ポストを見る ↗
          </a>
          <a
            href={`https://x.com/hashtag/${encodeURIComponent("homeクラ流行語")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center px-4 py-2 rounded-full bg-white text-brand text-sm font-bold border border-brand/30 hover:bg-brand-50 transition-colors"
          >
            {buzzwordAward.hashtag} を見る ↗
          </a>
        </div>
        <p class="mt-4 text-xs text-gray-500 leading-relaxed">{buzzwordAward.note}</p>
      </BentoCard>
    </section>

    <!-- Guidelines -->
    <section class="fade-up grid grid-cols-1 md:grid-cols-2 gap-4">
      <BentoCard title={viewerGuidelines.title} icon="🤝">
        <p class="text-xs font-bold text-brand mb-2">してほしいこと</p>
        <ul class="space-y-2 mb-5">
          {viewerGuidelines.dos.map((item) => (
            <li class="flex gap-2 text-sm text-gray-600 leading-relaxed">
              <span class="text-brand shrink-0">✓</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <p class="text-xs font-bold text-rose-600 mb-2">ご遠慮いただきたいこと</p>
        <ul class="space-y-2">
          {viewerGuidelines.donts.map((item) => (
            <li class="flex gap-2 text-sm text-gray-600 leading-relaxed">
              <span class="text-rose-500 shrink-0">×</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </BentoCard>

      <BentoCard title={forCreators.title} icon="🎬">
        <p class="text-sm text-gray-600 leading-relaxed">{forCreators.body}</p>
        <div class="mt-6 pt-4 border-t border-gray-100">
          <p class="text-xs font-bold text-gray-500 mb-3">関連リンク</p>
          <ul class="space-y-2">
            {homekuraLinks.map((link) => (
              <li>
                <a
                  href={link.url}
                  target={"internal" in link && link.internal ? undefined : "_blank"}
                  rel={"internal" in link && link.internal ? undefined : "noopener noreferrer"}
                  class="text-sm font-bold text-brand hover:text-brand-dark transition-colors"
                >
                  {link.label}
                  {!link.internal && <span class="text-[10px] ml-0.5 opacity-60">↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </BentoCard>
    </section>
  </div>
</Base>
