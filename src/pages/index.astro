---
import Base from "@/layouts/Base.astro";
import LiveStatus from "@/components/LiveStatus.astro";
import LatestVideo from "@/components/LatestVideo.astro";
import PopularVideos from "@/components/PopularVideos.astro";
import ShortVideos from "@/components/ShortVideos.astro";
import JisshaPeek from "@/components/JisshaPeek.astro";
import Schedule from "@/components/Schedule.astro";
import MembershipBenefits from "@/components/MembershipBenefits.astro";
import GoodsCard from "@/components/GoodsCard.astro";
import CommunityCard from "@/components/CommunityCard.astro";
import FeedbackCard from "@/components/FeedbackCard.astro";
import YouTubeHomeLoader from "@/components/YouTubeHomeLoader.astro";

import { getWeeklySchedule, getRealEvents, getMembershipBenefits, getWeeklyScheduleUpdatedAt } from "@/lib/data";
import { siteMeta } from "@/data/site-meta";
import { gameChannel, jisshaChannel } from "@/data/channels";

const weeklySchedule = await getWeeklySchedule();
const realEvents = await getRealEvents();
const benefits = await getMembershipBenefits();
const weeklyScheduleUpdatedAt = await getWeeklyScheduleUpdatedAt();
---

<Base title={siteMeta.homeTitle}>
  <div class="max-w-6xl mx-auto px-4 py-6 pb-28 sm:pb-6 space-y-4">
    <!-- YouTube API limit banner (shown by client scripts) -->
    <div
      id="youtube-api-limit-banner"
      class="hidden rounded-2xl border border-amber-200/70 bg-amber-50 px-4 py-3 text-sm text-amber-950 shadow-sm fade-up"
      role="status"
    >
      <div class="flex flex-col gap-3">
        <div>
          <p class="font-black leading-snug">
            おっと、予算の都合上起こるYouTube APIの制限の可能性が高い、再読み込みしてダメならすまない！
          </p>
          <p class="text-amber-900/90 text-xs mt-1.5 leading-relaxed">
            動画や配信予定は YouTube で直接見られます。下のボタンからどうぞ（サイト内の自動表示はクォータ復活までお待ちください）。
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a
            href={gameChannel.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-brand text-white text-sm font-black hover:bg-brand-dark transition-colors"
          >
            ゲームchを開く ↗
          </a>
          <a
            href={jisshaChannel.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-white text-brand text-sm font-black border border-brand/30 hover:bg-brand-50 transition-colors"
          >
            実写chを開く ↗
          </a>
          <button
            id="youtube-api-limit-reload"
            type="button"
            class="inline-flex items-center justify-center px-4 py-2 rounded-full bg-amber-900 text-white text-sm font-black hover:bg-amber-800 transition-colors"
          >
            再読み込み（試す）
          </button>
        </div>
      </div>
    </div>

    <script>
      // Global banner: can be triggered by any YouTube section.
      (function () {
        const banner = document.getElementById("youtube-api-limit-banner");
        if (!banner) return;
        const btn = document.getElementById("youtube-api-limit-reload");
        btn?.addEventListener("click", () => location.reload());

        const STORAGE_KEY = "youtube-limited-until";

        (window as any).__showYouTubeLimitBanner = function () {
          banner.classList.remove("hidden");
        };

        (window as any).__markYouTubeLimited = function (reason?: string) {
          const until =
            reason === "quotaExceeded"
              ? Date.now() + 6 * 60 * 60 * 1000
              : Date.now() + 20 * 60 * 1000;
          sessionStorage.setItem(STORAGE_KEY, String(until));
          banner.classList.remove("hidden");
        };

        (window as any).__isYouTubeLimited = function () {
          const raw = sessionStorage.getItem(STORAGE_KEY);
          if (!raw) return false;
          if (Date.now() < parseInt(raw, 10)) return true;
          sessionStorage.removeItem(STORAGE_KEY);
          return false;
        };

        if ((window as any).__isYouTubeLimited()) {
          banner.classList.remove("hidden");
        }
      })();
    </script>

    <!-- Live Status -->
    <LiveStatus />

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <!-- Schedule (full width) -->
      <div class="md:col-span-3 fade-up">
        <Schedule
          weeklySchedule={weeklySchedule}
          realEvents={realEvents}
          weeklyScheduleUpdatedAt={weeklyScheduleUpdatedAt}
        />
      </div>

      <!-- Latest Video -->
      <div class="md:col-span-1 fade-up">
        <LatestVideo />
      </div>

      <!-- Popular Videos -->
      <div class="md:col-span-2 fade-up">
        <PopularVideos />
      </div>

      <!-- Shorts (full width) -->
      <div class="md:col-span-3 fade-up">
        <ShortVideos />
      </div>

      <!-- Jissha channel peek -->
      <div class="md:col-span-3 fade-up">
        <JisshaPeek />
      </div>

      <!-- Community + Membership -->
      <div class="md:col-span-1 fade-up">
        <CommunityCard />
      </div>

      <div class="md:col-span-2 fade-up">
        <MembershipBenefits benefits={benefits} />
      </div>

      <!-- Goods + Feedback -->
      <div class="md:col-span-1 fade-up">
        <GoodsCard />
      </div>

      <div class="md:col-span-2 fade-up">
        <FeedbackCard />
      </div>
    </div>

    <YouTubeHomeLoader />
  </div>
</Base>
